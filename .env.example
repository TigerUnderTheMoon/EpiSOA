# === EpiSOA Environment Variables ===
# Copy this file to .env and fill in your API keys.
# .env is gitignored and will never be committed.

# --- LLM Provider (DeepSeek) ---
# Used by: configs/paper.yaml, configs/ablation.yaml
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- LLM Provider (OpenCode proxy) ---
# Used by: configs/opencode.yaml, configs/opencode_kimi.yaml
OPENCODE_API_KEY=sk-your-opencode-key
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# --- Search API ---
# Used by: configs/paper.yaml, configs/collector.yaml
SEARCH_API_KEY=your-search-api-key
SEARCH_BASE_URL=https://your-search-api-base-url/v1

# --- Search API (Bocha) ---
# Used by: configs/collector.yaml, configs/collector_tiny.yaml, etc.
BOCHA_API_KEY=your-bocha-api-key
BOCHA_BASE_URL=https://api.bochaai.com/v1

# --- Generic OpenAI-compatible fallback ---
# Used by: configs/default.yaml (mock mode by default)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
